# ==== AmoCRM (backend) =======================================================
# Hisob subdomeni: mycompany.amocrm.ru  ->  AMOCRM_SUBDOMAIN=mycompany
AMOCRM_SUBDOMAIN=
# Uzoq muddatli access token (AmoCRM > Sozlamalar > Integratsiyalar)
AMOCRM_ACCESS_TOKEN=
# Agar hisob .com domenida bo'lsa, to'liq URL bering (subdomain o'rniga):
# AMOCRM_BASE_URL=https://mycompany.amocrm.com

# Har bir forma uchun voronka (pipeline) va bosqich (status) ID:
# POS forma  -> POS New / Входящий
AMOCRM_POS_PIPELINE_ID=9857042
AMOCRM_POS_STATUS_ID=78392222
# SFA forma  -> SFA New / Неразобранное
AMOCRM_SFA_PIPELINE_ID=10394262
AMOCRM_SFA_STATUS_ID=82159642
# Ixtiyoriy: mas'ul foydalanuvchi ID
AMOCRM_RESPONSIBLE_ID=

# Backend porti
PORT=3001

# ==== Frontend (Vite) ========================================================
# Yakunda redirect qilinadigan Telegram bot havolasi (umumiy, fallback).
# Har bir formaga alohida bot kerak bo'lsa src/forms.config.js da telegramUrl bering.
VITE_TELEGRAM_URL=https://t.me/linko_sotuv_bot
